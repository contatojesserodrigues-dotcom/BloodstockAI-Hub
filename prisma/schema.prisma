generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum AgentStatus {
  IDLE
  RESEARCHING
  WRITING
  WAITING_APPROVAL
  SENDING_APPROVED
  UPDATING_CRM
  MEETING_SCHEDULED
  MONITORING
  ANALYZING
  ERROR
  COMPLETED
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  EDITED
}

enum PipelineStage {
  NEW_LEAD
  RESEARCHED
  CONTACT_DRAFTED
  CONTACT_APPROVED
  CONTACTED
  OPENED
  REPLIED
  MEETING_BOOKED
  PROPOSAL_SENT
  NEGOTIATION
  WON
  LOST
}

enum AIProvider {
  CLAUDE
  OPENAI
  GEMINI
  PERPLEXITY
  LOCAL
}

model Agent {
  id            String      @id @default(cuid())
  slug          String      @unique
  name          String
  role          String
  room          String
  bio           String?
  status        AgentStatus @default(IDLE)
  currentTask   String?
  lastAction    String?
  tools         String
  avatarColor   String      @default("#8B1538")
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  tasks         AgentTask[]
  logs          AgentLog[]
  emailDrafts   EmailDraft[]
  approvals     ApprovalRequest[]
  conversations Conversation[]
}

model AgentTask {
  id          String      @id @default(cuid())
  agentId     String
  title       String
  description String?
  status      String      @default("pending")
  priority    String      @default("medium")
  createdAt   DateTime    @default(now())
  completedAt DateTime?

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)
}

model AgentLog {
  id        String   @id @default(cuid())
  agentId   String
  message   String
  level     String   @default("info")
  createdAt DateTime @default(now())

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)
}

model ToolConnection {
  id        String   @id @default(cuid())
  provider  String   @unique
  label     String
  connected Boolean  @default(false)
  config    String?
  updatedAt DateTime @updatedAt
}

model Lead {
  id          String        @id @default(cuid())
  name        String
  email       String?
  company     String?
  country     String?
  segment     String?
  stage       PipelineStage @default(NEW_LEAD)
  value       Float         @default(0)
  source      String?
  notes       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  companyRef Company? @relation(fields: [companyId], references: [id])
  companyId  String?
  deals      CRMDeal[]
}

model Company {
  id        String   @id @default(cuid())
  name      String
  country   String?
  website   String?
  segment   String?
  notes     String?
  createdAt DateTime @default(now())

  leads    Lead[]
  contacts Contact[]
}

model Contact {
  id        String   @id @default(cuid())
  name      String
  email     String?
  title     String?
  companyId String?
  createdAt DateTime @default(now())

  company Company? @relation(fields: [companyId], references: [id])
}

model EmailDraft {
  id        String         @id @default(cuid())
  agentId   String
  subject   String
  body      String
  recipient String
  status    ApprovalStatus @default(PENDING)
  createdAt DateTime       @default(now())

  agent     Agent            @relation(fields: [agentId], references: [id])
  approvals ApprovalRequest[]
}

model ApprovalRequest {
  id          String         @id @default(cuid())
  agentId     String
  type        String
  title       String
  description String?
  preview     String?
  riskLevel   String         @default("low")
  status      ApprovalStatus @default(PENDING)
  leadId      String?
  emailDraftId String?
  createdAt   DateTime       @default(now())
  resolvedAt  DateTime?

  agent      Agent       @relation(fields: [agentId], references: [id])
  emailDraft EmailDraft? @relation(fields: [emailDraftId], references: [id])
}

model CRMDeal {
  id        String        @id @default(cuid())
  title     String
  value     Float
  stage     PipelineStage @default(NEW_LEAD)
  leadId    String?
  owner     String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  lead Lead? @relation(fields: [leadId], references: [id])
}

model Meeting {
  id        String   @id @default(cuid())
  title     String
  attendee  String?
  datetime  DateTime
  status    String   @default("scheduled")
  notes     String?
  createdAt DateTime @default(now())
}

model Campaign {
  id        String   @id @default(cuid())
  name      String
  status    String   @default("draft")
  sent      Int      @default(0)
  opened    Int      @default(0)
  replied   Int      @default(0)
  createdAt DateTime @default(now())
}

model Conversation {
  id        String   @id @default(cuid())
  agentId   String?
  role      String
  content   String
  createdAt DateTime @default(now())

  agent Agent? @relation(fields: [agentId], references: [id])
}

model ProviderConfig {
  id        String     @id @default(cuid())
  provider  AIProvider @unique
  enabled   Boolean    @default(false)
  model     String?
  updatedAt DateTime   @updatedAt
}
