generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum AgentStatus {
  IDLE
  RESEARCHING
  WRITING
  WAITING_APPROVAL
  SENDING_APPROVED
  UPDATING_CRM
  MEETING_SCHEDULED
  MONITORING
  ANALYZING
  ERROR
  COMPLETED
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  EDITED
}

enum PipelineStage {
  NEW_LEAD
  RESEARCHED
  CONTACT_DRAFTED
  CONTACT_APPROVED
  CONTACTED
  OPENED
  REPLIED
  MEETING_BOOKED
  PROPOSAL_SENT
  NEGOTIATION
  WON
  LOST
}

enum AIProvider {
  CLAUDE
  OPENAI
  GEMINI
  PERPLEXITY
  GROK
  LOCAL
}

enum OrgType {
  COMPANY
  PERSONAL
}

enum MembershipRole {
  OWNER
  ADMIN
  MEMBER
}

model HubUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Organization {
  id             String   @id @default(cuid())
  name           String
  type           OrgType  @default(COMPANY)
  industry       String?
  country        String?
  language       String?  @default("en")
  employeeCount  String?
  objectives     String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  memberships Membership[]
  workspaces  Workspace[]
  agents      Agent[]
  documents   KnowledgeDocument[]
  integrations Integration[]
  workflows   Workflow[]
  subscriptions Subscription[]
  auditLogs   AuditLog[]
}

model Membership {
  id        String         @id @default(cuid())
  userEmail String
  orgId     String
  role      MembershipRole @default(OWNER)
  createdAt DateTime       @default(now())

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([userEmail, orgId])
  @@index([userEmail])
}

model Workspace {
  id        String   @id @default(cuid())
  orgId     String
  name      String
  createdAt DateTime @default(now())

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
}

model AgentTemplate {
  id           String   @id @default(cuid())
  slug         String   @unique
  name         String
  department   String
  role         String
  description  String?
  capabilities String
  integrations String?
  industryPack String?
  avatarColor  String   @default("#6A0DAD")
  createdAt    DateTime @default(now())

  agents Agent[]
}

model Agent {
  id             String      @id @default(cuid())
  slug           String      @unique
  name           String
  role           String
  room           String
  bio            String?
  status         AgentStatus @default(IDLE)
  currentTask    String?
  lastAction     String?
  tools          String
  avatarColor    String      @default("#6A0DAD")
  organizationId String?
  templateId     String?
  objective      String?
  personality    String?
  skills         String?
  permissions    String?
  memoryEnabled  Boolean     @default(true)
  knowledgeSources String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  organization  Organization? @relation(fields: [organizationId], references: [id])
  template      AgentTemplate? @relation(fields: [templateId], references: [id])
  tasks         AgentTask[]
  logs          AgentLog[]
  emailDrafts   EmailDraft[]
  approvals     ApprovalRequest[]
  conversations Conversation[]
  memories      AgentMemory[]
}

model AgentMemory {
  id        String   @id @default(cuid())
  agentId   String
  key       String
  value     String
  createdAt DateTime @default(now())

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)
}

model AgentTask {
  id          String      @id @default(cuid())
  agentId     String
  title       String
  description String?
  status      String      @default("pending")
  priority    String      @default("medium")
  createdAt   DateTime    @default(now())
  completedAt DateTime?

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)
}

model AgentLog {
  id        String   @id @default(cuid())
  agentId   String
  message   String
  level     String   @default("info")
  createdAt DateTime @default(now())

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)
}

model ToolConnection {
  id        String   @id @default(cuid())
  provider  String   @unique
  label     String
  connected Boolean  @default(false)
  config    String?
  updatedAt DateTime @updatedAt
}

model Lead {
  id          String        @id @default(cuid())
  name        String
  email       String?
  company     String?
  country     String?
  segment     String?
  stage       PipelineStage @default(NEW_LEAD)
  value       Float         @default(0)
  source      String?
  notes       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  companyRef Company? @relation(fields: [companyId], references: [id])
  companyId  String?
  deals      CRMDeal[]
}

model Company {
  id        String   @id @default(cuid())
  name      String
  country   String?
  website   String?
  segment   String?
  notes     String?
  createdAt DateTime @default(now())

  leads    Lead[]
  contacts Contact[]
}

model Contact {
  id        String   @id @default(cuid())
  name      String
  email     String?
  title     String?
  companyId String?
  createdAt DateTime @default(now())

  company Company? @relation(fields: [companyId], references: [id])
}

model EmailDraft {
  id        String         @id @default(cuid())
  agentId   String
  subject   String
  body      String
  recipient String
  status    ApprovalStatus @default(PENDING)
  createdAt DateTime       @default(now())

  agent     Agent            @relation(fields: [agentId], references: [id])
  approvals ApprovalRequest[]
}

model ApprovalRequest {
  id          String         @id @default(cuid())
  agentId     String
  type        String
  title       String
  description String?
  preview     String?
  riskLevel   String         @default("low")
  status      ApprovalStatus @default(PENDING)
  leadId      String?
  emailDraftId String?
  createdAt   DateTime       @default(now())
  resolvedAt  DateTime?

  agent      Agent       @relation(fields: [agentId], references: [id])
  emailDraft EmailDraft? @relation(fields: [emailDraftId], references: [id])
}

model CRMDeal {
  id        String        @id @default(cuid())
  title     String
  value     Float
  stage     PipelineStage @default(NEW_LEAD)
  leadId    String?
  owner     String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  lead Lead? @relation(fields: [leadId], references: [id])
}

model Meeting {
  id        String   @id @default(cuid())
  title     String
  attendee  String?
  datetime  DateTime
  status    String   @default("scheduled")
  notes     String?
  createdAt DateTime @default(now())
}

model Campaign {
  id        String   @id @default(cuid())
  name      String
  status    String   @default("draft")
  sent      Int      @default(0)
  opened    Int      @default(0)
  replied   Int      @default(0)
  createdAt DateTime @default(now())
}

model Conversation {
  id        String   @id @default(cuid())
  agentId   String?
  role      String
  content   String
  createdAt DateTime @default(now())

  agent Agent? @relation(fields: [agentId], references: [id])
}

model ProviderConfig {
  id        String     @id @default(cuid())
  provider  AIProvider @unique
  enabled   Boolean    @default(false)
  model     String?
  updatedAt DateTime   @updatedAt
}

model KnowledgeDocument {
  id             String   @id @default(cuid())
  organizationId String
  title          String
  content        String?
  sourceUrl      String?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model Integration {
  id             String   @id @default(cuid())
  organizationId String
  provider       String
  label          String
  connected      Boolean  @default(false)
  configEnc      String?
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, provider])
}

model Workflow {
  id             String   @id @default(cuid())
  organizationId String?
  name           String
  trigger        String?
  actions        String?
  graph          String?
  engine         String   @default("native")
  enabled        Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  executions   WorkflowExecution[]
}

model WorkflowExecution {
  id         String   @id @default(cuid())
  workflowId String
  status     String   @default("pending")
  result     String?
  createdAt  DateTime @default(now())

  workflow Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
}

model Subscription {
  id             String   @id @default(cuid())
  organizationId String
  plan           String   @default("starter")
  status         String   @default("active")
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id             String   @id @default(cuid())
  organizationId String?
  actorEmail     String?
  action         String
  meta           String?
  createdAt      DateTime @default(now())

  organization Organization? @relation(fields: [organizationId], references: [id])
}
