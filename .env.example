# ─── Local dev only ───
DATABASE_URL="file:./dev.db"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
HUB_URL="http://localhost:3000"

# ─── Admin Login (required) ───
ADMIN_EMAIL="admin@bloodstockai.com"
ADMIN_PASSWORD="change-me"
ADMIN_SESSION_SECRET="generate-a-random-secret-min-32-chars"

# ─── Supabase — primary production backend ───
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# ─── Claude — sole reasoning engine ───
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-sonnet-4-20250514"

# ─── Tavily — web research only ───
TAVILY_API_KEY=""

# ─── HubSpot — CRM (optional) ───
HUBSPOT_ACCESS_TOKEN=""

# ─── n8n — automation & external execution (approval-gated) ───
N8N_BASE_URL="https://bloodstockai.app.n8n.cloud"
N8N_AGENT_WEBHOOK_URL="https://bloodstockai.app.n8n.cloud/webhook/agent-command"
N8N_WEBHOOK_AGENT="/webhook/agent-command"
N8N_WEBHOOK_WORKFLOW="/webhook/consignor-workflow"
N8N_WEBHOOK_SEND_APPROVED="/webhook/send-approved-emails"
N8N_WEBHOOK_SECRET=""
